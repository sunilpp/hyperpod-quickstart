{
  "dashboard": {
    "uid": "hyperpod-gpu-utilization",
    "title": "HyperPod GPU Utilization",
    "description": "NVIDIA GPU metrics via DCGM exporter",
    "tags": ["hyperpod", "gpu", "dcgm"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus"
        },
        {
          "name": "instance",
          "type": "query",
          "datasource": { "uid": "${datasource}" },
          "query": "label_values(DCGM_FI_DEV_GPU_UTIL, instance)",
          "multi": true,
          "includeAll": true
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "GPU Utilization %",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [{ "expr": "DCGM_FI_DEV_GPU_UTIL{instance=~\"$instance\"}", "legendFormat": "{{ instance }} GPU{{ gpu }}" }],
        "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
      },
      {
        "id": 2,
        "title": "GPU Memory Used %",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [{ "expr": "DCGM_FI_DEV_FB_USED{instance=~\"$instance\"} / (DCGM_FI_DEV_FB_USED{instance=~\"$instance\"} + DCGM_FI_DEV_FB_FREE{instance=~\"$instance\"}) * 100", "legendFormat": "{{ instance }} GPU{{ gpu }}" }],
        "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
      },
      {
        "id": 3,
        "title": "GPU Temperature",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [{ "expr": "DCGM_FI_DEV_GPU_TEMP{instance=~\"$instance\"}", "legendFormat": "{{ instance }} GPU{{ gpu }}" }],
        "fieldConfig": { "defaults": { "unit": "celsius", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 85 }] } } }
      },
      {
        "id": 4,
        "title": "GPU Power Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [{ "expr": "DCGM_FI_DEV_POWER_USAGE{instance=~\"$instance\"}", "legendFormat": "{{ instance }} GPU{{ gpu }}" }],
        "fieldConfig": { "defaults": { "unit": "watt" } }
      },
      {
        "id": 5,
        "title": "Tensor Core Activity",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [{ "expr": "DCGM_FI_PROF_PIPE_TENSOR_ACTIVE{instance=~\"$instance\"}", "legendFormat": "{{ instance }} GPU{{ gpu }}" }],
        "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
      },
      {
        "id": 6,
        "title": "NVLink Throughput",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          { "expr": "DCGM_FI_PROF_NVLINK_TX_BYTES{instance=~\"$instance\"}", "legendFormat": "{{ instance }} GPU{{ gpu }} TX" },
          { "expr": "DCGM_FI_PROF_NVLINK_RX_BYTES{instance=~\"$instance\"}", "legendFormat": "{{ instance }} GPU{{ gpu }} RX" }
        ],
        "fieldConfig": { "defaults": { "unit": "Bps" } }
      }
    ]
  }
}
